# ── Required ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_ai_studio_key
SERPER_API_KEY=your_serper_dev_key
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=Axiom

# ── Optional: fallback providers (strongly recommended in production) ─────────
# Secondary Gemini key — fresh daily quota pool (different Google account)
# GEMINI_API_KEY_2=

# Groq API key — enables Llama-3.1-70b as the final quota-exhaustion fallback
# Free tier: ~14,000 tokens/min, separate quota from Gemini  https://console.groq.com
# GROQ_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list.  localhost:3000 is always added automatically in dev.
# For production set this to your Vercel deployment URL:
ALLOWED_ORIGINS=http://localhost:3000
# ALLOWED_ORIGINS=https://axiom.vercel.app,http://localhost:3000

# ── Misc ──────────────────────────────────────────────────────────────────────
# Set LOG_LEVEL=INFO for verbose local logging (production defaults to WARNING)
LOG_LEVEL=INFO
